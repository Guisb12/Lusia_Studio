NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# ── Web / local dev ─────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
BACKEND_API_URL=http://localhost:8000

# ── Capacitor – Android emulator ────────────────────────────────────────────
# NEXT_PUBLIC_API_BASE_URL=http://10.0.2.2:8000
# CAPACITOR_SERVER_URL=http://10.0.2.2:3000

# ── Capacitor – real device on LAN (replace with your machine's LAN IP) ─────
# NEXT_PUBLIC_API_BASE_URL=http://192.168.1.64:8000
# CAPACITOR_SERVER_URL=http://192.168.1.64:3000
# NEXT_PUBLIC_API_BASE_URL is read by the browser; use the LAN IP, not localhost
# CAPACITOR_SERVER_URL is read by capacitor.config.ts; it also drives allowedDevOrigins

CAPACITOR_SERVER_URL=http://localhost:3000
CAPACITOR_APP_ID=com.lusiastudio.student
CAPACITOR_APP_NAME="LUSIA Student"
NEXT_PUBLIC_CAPACITOR_AUTH_SCHEME=com.lusiastudio.student
CAPACITOR_ALLOW_NAVIGATION=localhost:3000,localhost:8000
